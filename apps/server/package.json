{
  "name": "@tt/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --require ./load-env.js --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "crawl": "ts-node --require ./load-env.js src/jobs/crawl.ts",
    "summarize": "ts-node --require ./load-env.js src/jobs/summarize.ts",
    "publish": "ts-node --require ./load-env.js src/jobs/publish.ts",
    "db:generate": "prisma generate",
    "db:migrate": "sh -c 'set -a && . ../../.env && set +a && prisma migrate dev'",
    "db:seed": "ts-node --require ./load-env.js prisma/seed.ts",
    "db:studio": "sh -c 'set -a && . ../../.env && set +a && prisma studio'"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "cors": "^2",
    "dotenv": "^16",
    "express": "^4",
    "node-cron": "^3",
    "openai": "^4",
    "rss-parser": "^3"
  },
  "devDependencies": {
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3",
    "prisma": "^6",
    "ts-node": "^10",
    "ts-node-dev": "^2",
    "typescript": "^5"
  }
}
